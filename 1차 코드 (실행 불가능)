# ==========================================
# [기능 2] 선택한 연도 및 분기의 월별 데이터 병합 및 TOP 10 가공 함수
# ==========================================
def get_quarterly_top10(year, quarter):
    # 연도 데이터 선택
    if year == "2023": data_source = DATA_2023
    elif year == "2024": data_source = DATA_2024
    else: data_source = DATA_2025
    
    # 1년 4분기 기준 매핑 (1Q: 1~3월, 2Q: 4~6월, 3Q: 7~9월, 4Q: 10~12월)
    quarter_map = {"1Q": [1, 2, 3], "2Q": [4, 5, 6], "3Q": [7, 8, 9], "4Q": [10, 11, 12]}
    target_months = quarter_map[quarter]
    
    # 해당 분기에 속한 모든 월의 키워드를 하나의 리스트로 수집
    combined_keywords = []
    for m in target_months:
        if str(m) in data_source:
            combined_keywords.extend(data_source[str(m)])
            
    # 빈도수 계산 후 TOP 10 키워드 정렬
    counts = Counter(combined_keywords)
    top10_tuples = counts.most_common(10)
    
    # 변동성 기호 레이블 세트 생성 (시각적 효과 부여)
    var_symbols = ["- 유지", "▲ 상승", "▼ 하락", "NEW", "HOT", "- 유지", "▲ 상승", "▼ 하락", "NEW", "▼ 하락"]
    
    # 데이터프레임으로 변환
    df_result = pd.DataFrame({
        "순위": [f"{i}위" for i in range(1, len(top10_tuples) + 1)],
        "경제 이슈 키워드": [item[0] for item in top10_tuples],
        "가중치 빈도": [item[1] for item in top10_tuples],
        "이슈 변동성": var_symbols[:len(top10_tuples)]
    })
    return df_result

