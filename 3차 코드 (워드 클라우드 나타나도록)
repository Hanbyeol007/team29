    neg_count = sum(1 for word in freq_dict.keys() if word in SENTIMENT_DICT["부정"])
    
    # 바 차트 데이터 빌드
    sentiment_summary = pd.DataFrame({
        "감성 성향": ["긍정 성향 단어", "부정 성향 단어"],
        "매칭 단어수": [pos_count, neg_count]
    })
    
    fig_bar, ax_bar = plt.subplots(figsize=(6, 4.2))
    custom_colors = ['#1e5af0', '#f02828'] # 긍정 블루, 부정 레드
    bars = ax_bar.bar(sentiment_summary["감성 성향"], sentiment_summary["매칭 단어수"], color=custom_colors, width=0.45)
    
    # 바 그래프 눈금 및 수치 추가
    ax_bar.bar_label(bars, fmt='%d개', padding=4)
    ax_bar.set_ylabel("단어 종류 수")
    ax_bar.set_title("TOP 10 키워드 중 감성 속성 분포")
    ax_bar.set_ylim(0, max(pos_count, neg_count) + 1) # 여백 조정
    st.pyplot(fig_bar)
    
    # 정량적 감성 비중 메트릭 카드 표출
    total_sentiment = pos_count + neg_count
    if total_sentiment > 0:
        pos_ratio = (pos_count / total_sentiment) * 100
        st.metric(label="📈 선택 분기 트렌드 낙관도 (긍정 비율)", value=f"{pos_ratio:.1f}%")
    else:
        st.info("💡 해당 분기 TOP 10 키워드는 모두 시장 중립 성향의 단어로 구성되어 있습니다.")
