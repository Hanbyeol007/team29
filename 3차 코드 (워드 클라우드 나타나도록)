# [기능 4] 감성 워드클라우드 개별 색상 지정 함수 (긍정:파랑, 부정:빨강)
# ==========================================
def get_sentiment_color(word, font_size, position, orientation, random_state=None, **kwargs):
    if word in SENTIMENT_DICT["긍정"]:
        return "rgb(30, 90, 240)"   # 긍정 단어: 파란색
    elif word in SENTIMENT_DICT["부정"]:
        return "rgb(240, 40, 40)"   # 부정 단어: 빨간색
    else:
        return "rgb(120, 120, 120)" # 일반/중립 단어: 회색

