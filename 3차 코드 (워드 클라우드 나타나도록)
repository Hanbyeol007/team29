# [기능 2] 선택된 분기(3개 월) 데이터 병합 및 TOP 10 추출 함수
# ==========================================
def get_quarterly_top10(year, quarter):
    quarter_map = {
        "1분기": ["1", "2", "3"],
        "2분기": ["4", "5", "6"],
        "3분기": ["7", "8", "9"],
        "4분기": ["10", "11", "12"]
    }
    
    target_months = quarter_map[quarter]
    year_data = RAW_DATA[year]
    
    combined_words = []
    for m in target_months:
        combined_words.extend(year_data[m])
        
    # 데이터셋 자체의 단어 빈도 계산
    from collections import Counter
    counts = Counter(combined_words)
    top10_list = counts.most_common(10)
    
    # 변동성 기호 패턴 정의
    symbols = ["- 유지", "▲ 상승", "▼ 하락", "▲ 상승", "▼ 하락", "NEW", "HOT", "- 유지", "▲ 상승", "▼ 하락"]
    
    df = pd.DataFrame({
        "순위": [f"{i}위" for i in range(1, len(top10_list) + 1)],
        "경제 키워드": [item[0] for item in top10_list],
        "가중치(노출수)": [item[1] for item in top10_list],
        "변동성": symbols[:len(top10_list)]
    })
    return df, dict(top10_list)

