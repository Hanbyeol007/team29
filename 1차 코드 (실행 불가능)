# 📂 뉴스 텍스트 형태소(명사) 분석 및 감성 계산 함수
def analyze_text_sentiment(text):
    okt = Okt()
    # 명사 추출 수행
    nouns = okt.nouns(text)
    # 한 글자짜리 불용어 단어는 제거
    nouns = [n for n in nouns if len(n) > 1]
    
    pos_found = [n for n in nouns if n in SENTIMENT_DICT["긍정"]]
    neg_found = [n for n in nouns if n in SENTIMENT_DICT["부정"]]
    
    return nouns, pos_found, neg_found

# ==========================================
# [기능 4] 감성 사전에 따른 워드클라우드 개별 채색 함수 (긍정:파랑, 부정:빨강)
# ==========================================
def design_sentiment_color(word, font_size, position, orientation, random_state=None, **kwargs):
    if word in SENTIMENT_DICT["긍정"]:
        return "rgb(40, 110, 250)"   # 긍정: 시원한 파란색 계열
    elif word in SENTIMENT_DICT["부정"]:
        return "rgb(255, 60, 60)"    # 부정: 강렬한 빨간색 계열
    else:
        return "rgb(130, 130, 130)"  # 중립 단어: 차분한 회색

