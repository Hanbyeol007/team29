    # 형태소 분석 및 동적 스코어링 가동
    all_nouns, pos_words, neg_words = analyze_text_sentiment(text_content)
    
    # 4. 메인 화면 - [하단] 워드클라우드 및 감성 지수 차트 시각화
    st.subheader("3️⃣ 업로드 텍스트 기반 시각화 및 감성지수 리포트")
    
    # 2열 분할 레이아웃 배치
    layout_col1, layout_col2 = st.columns(2)
    
    with layout_col1:
        st.markdown("#### 🟥🟦 감성 어휘 워드클라우드")
        if len(all_nouns) > 0:
            noun_counts = Counter(all_nouns)
            
            # 운영체제에 부합하는 시스템 기본 폰트 파일 탐색 지정
            chosen_font = "malgun.ttf" if platform.system() == "Windows" else "AppleGothic.ttf"
            
            try:
                # 워드클라우드 객체 인스턴스 빌드
                cloud_obj = WordCloud(
                    font_path=chosen_font,
                    background_color="white",
                    width=600,
                    height=400,
                    max_words=60
                ).generate_from_frequencies(noun_counts)
                
                # 정의해둔 감성 컬러맵 함수 맵핑 적용
                cloud_obj.recolor(color_func=design_sentiment_color)
                
                # Matplotlib 캔버스 드로잉
                fig_cloud, ax_cloud = plt.subplots(figsize=(6, 4))
                ax_cloud.imshow(cloud_obj, interpolation="bilinear")
                ax_cloud.axis("off")
                st.pyplot(fig_cloud)
            except Exception as font_error:
                st.info("환경별 기본 폰트 로드 우회 중입니다. 키워드 단순 빈도 막대그래프로 대체 표출합니다.")
                st.bar_chart(pd.Series(noun_counts).head(10))
        else:
            st.warning("분석용 텍스트에 인식 가능한 한글 단어(명사)가 존재하지 않습니다.")

    with layout_col2:
        st.markdown("#### 📊 주요 핵심 감성 표현 등장 추이")
        cnt_pos = len(pos_words)
        cnt_neg = len(neg_words)
        total_matched = cnt_pos + cnt_neg
        
        if total_matched > 0:
            # 시각화용 데이터프레임 구조 정의
            chart_data = pd.DataFrame({
                "감성 유형": ["긍정 성향 단어", "부정 성향 단어"],
                "매칭 빈도수": [cnt_pos, cnt_neg]
            })
            
            # Matplotlib 기반 바 차트 구현
            fig_bar, ax_bar = plt.subplots(figsize=(6, 4))
            bar_colors = ['#286efa', '#ff3c3c']  # 요구사항 반영: 긍정 파랑, 부정 빨강
            render_bars = ax_bar.bar(chart_data["감성 유형"], chart_data["매칭 빈도수"], color=bar_colors, width=0.4)
            
            # 막대 그래픽 상단에 수치 라벨 추가 규칙 정의
            ax_bar.bar_label(render_bars, fmt='%d개', padding=4)
            ax_bar.set_ylabel("매칭 단어 개수")
            ax_bar.set_title("텍스트 내부 긍정/부정 감성 단어 빈도 비교")
            
            st.pyplot(fig_bar)
            
            # 감성 지수 비중 정량 스코어 요약 카드 배치
            sentiment_ratio = (cnt_pos / total_matched) * 100
            st.metric(label="📈 최종 기사 낙관도 지수 (긍정 단어 비율)", value=f"{sentiment_ratio:.1f}%")
        else:
            st.info("💡 본문 기사에서 미리 정의된 감성 사전 사전과 매칭되는 명사가 탐지되지 않았습니다. (중립 보도자료 양식)")

else:
    # 파일 미업로드 시 초기 상태 대기 안내 메시지 가이드라인 표출
    st.info("👋 좌측 사이드바 필터를 변경하여 분기별 트렌드를 확인하세요. 기사 본문 파일(.txt)을 업로드하면 하단에 실시간 감성 시각화 대시보드가 활성화됩니다.")
